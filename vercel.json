{
  "version": 2,
  "builds": [
    {
      "src": "fooddelivery/fooddelivery/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9",
        "includeFiles": ["fooddelivery/db.sqlite3"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "fooddelivery/fooddelivery/wsgi.py"
    }
  ]
}
